# Flask
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-secret

# Database
DATABASE_URL=sqlite:///sentimentsignal.db

# JWT
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret

# Finnhub (https://finnhub.io) — primary news source
FINNHUB_API_KEY=your_finnhub_api_key_here

# NewsAPI (https://newsapi.org) — secondary news source
NEWSAPI_API_KEY=your_newsapi_api_key_here

# Internal API key for protected routes
INTERNAL_API_KEY=dev-secret-key
