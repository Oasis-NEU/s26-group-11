# Flask
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-secret

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/sentimentsignal

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret

# Reddit API (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=SentimentSignal/1.0

# NewsAPI (https://newsapi.org)
NEWS_API_KEY=

# Finnhub (https://finnhub.io)
FINNHUB_API_KEY=

# Hugging Face (https://huggingface.co/settings/tokens) — for FinBERT
HUGGINGFACE_API_TOKEN=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
